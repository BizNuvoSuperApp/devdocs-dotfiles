#!/usr/bin/env bash

_checkUpdateNeeded() {
    local dir=$HOME/update-lock-timestamps
    local file=$dir/${1}.tz

    if [[ ! -f $file ]]; then
        mkdir -p $dir
        touch $file
        return 0
    fi

    local timeArg=${2:-1d}
    local time=${timeArg::-1}
    local timeType=${timeArg:(-1)}

    case "$timeType" in
    "m") time=$(($time * 60));;
    "h") time=$(($time * 3600)) ;;
    "d") time=$(($time * 86400)) ;;
    "*") return 1 ;;
    esac

    local currentTime=$(date +%s)
    local fileTime=$(stat -c %Y $file)

    if (($currentTime - $fileTime < $time)); then
        touch $file
        return 0
    fi

    return 1
}


filterArg=${1:-}


if ! which gum >/dev/null 2>&1 ; then
    winget install charmbracelet.gum
elif _checkUpdateNeeded gum 7d; then
    echo "== Updating CLI tools =="
    winget update charmbracelet.gum
fi


ssh_hosts=("Exit Quit")
foundHosts=false

while read -r ssh_host; do
    ssh_hosts+=("$ssh_host")
    foundHosts=true
done < <(awk 'tolower($1) == "host" && $2 !~ /github/ {print $2}' ~/.ssh/config | grep "$filterArg")

if [[ $foundHosts != true ]]; then
    echo "No host aliases defined in config file"
    exit 1
fi

resp=$(gum filter --limit=1 --timeout=10s --header="Pick SSH host to connect to:" "${ssh_hosts[@]}")

if [[ -n $resp && $resp != 'Exit Quit' ]]; then
    ssh $resp
fi
