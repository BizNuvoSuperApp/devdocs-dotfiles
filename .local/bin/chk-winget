#!/bin/bash
#
# ARG_OPTIONAL_BOOLEAN([force],[f],[Force update])
# ARG_POSITIONAL_SINGLE([package],[Winget package],[])
# ARG_POSITIONAL_SINGLE([cmd],[bash cmd],[])
# ARG_POSITIONAL_SINGLE([time],[time check],[2d])
# ARGBASH_GO()
# needed because of Argbash --> m4_ignore([
### START OF CODE GENERATED BY Argbash v2.11.0 one line above ###
